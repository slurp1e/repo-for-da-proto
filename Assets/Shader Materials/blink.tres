[gd_resource type="Shader" format=3 uid="uid://yb82stsfnuf"]

[resource]
code = "shader_type canvas_item;

uniform float flash_intensity : hint_range(0.0, 1.0) = 1.0;

void fragment() {
	vec4 tex = texture(TEXTURE, UV);

	// full white flash effect
	vec3 flash = vec3(1.0);

	vec3 final_color = mix(tex.rgb, flash, flash_intensity);

	COLOR = vec4(final_color, tex.a);
}
"
